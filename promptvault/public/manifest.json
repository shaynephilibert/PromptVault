{
  "manifest_version": 3,
  "name": "PromptVault — Private AI Prompt Manager",
  "version": "1.0.4",
  "description": "Save, organize, and inject prompts into any AI. Encrypted locally. No account. No server. Your data never leaves your browser.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://grok.com/*"
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content/chatgpt.js"]
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content/claude.js"]
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content/gemini.js"]
    },
    {
      "matches": ["https://grok.com/*"],
      "js": ["content/grok.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
